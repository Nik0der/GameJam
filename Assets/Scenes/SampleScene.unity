  m_text: "\u0421\u0430\u0431\u0438\u0442\u043E\u0432 \u0411\u0440\u043E\u043D\u0438\u0441\u043B\u0430\u0432
    - \u0422\u0438\u043C\u043B\u0438\u0434, \u0442\u0430\u043B\u0438\u0441\u043C\u0430\u043D;\n\n\u0414\u0430\u0434\u0430\u0439\u043A\u0438\u043D
    \u0410\u043D\u0434\u0440\u0435\u0439 - \u041A\u0440\u0435\u0430\u0442\u0438\u0432\u043D\u044B\u0439
    \u0414\u0438\u0440\u0435\u043A\u0442\u043E\u0440;\n\n\u0421\u0430\u0432\u0430\u0442\u0435\u0435\u0432
